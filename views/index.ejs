<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
  <h1><%= title %></h1>

  <a href="/new">Add New Message</a>

  <ul>
    <% messages.forEach((msg, index) => { %>
      <li>
        <strong><%= msg.user %></strong>: <%= msg.text %><br>
        <small><%= msg.added.toLocaleString() %></small><br>
        <a href="/message/<%= index %>">Open</a>
      </li>
    <% }) %>
  </ul>
</body>
</html>